# Copy this file to .env and fill in real values.
# The app runs fully WITHOUT these set -- it falls back to local
# sentence-transformer embeddings and a template-based response generator.

# Optional: enables real Gemini responses + Google embeddings
GEMINI_API_KEY=

# Optional: point at a real Qdrant server (e.g. from docker-compose).
# If unset, Qdrant runs embedded/local at ./qdrant_data
QDRANT_URL=
